// form5472 Prisma schema — full shape from the product spec.
// Phase 1 uses only User, Filing, FilingYearData. BankStatement and
// related fields are present so Phase 2 (CSV parsing) is a pure additive change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  createdAt            DateTime          @default(now())
  // Marketing emails (yearly file-again reminders, etc). Defaults to opted-in
  // since customers signed up by buying a filing; flipped via /unsubscribe.
  emailMarketingOptOut Boolean           @default(false)
  filings              Filing[]
  reminders            ReminderSent[]
  einApplications      EinApplication[]
  itinApplications     ItinApplication[]
}

model Admin {
  id           String             @id @default(cuid())
  email        String             @unique
  name         String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  lastLoginAt  DateTime?
  loginNonce   String?
  deviceTokens AdminDeviceToken[]
  changeLog    FilingChangeLog[]
}

model AdminDeviceToken {
  id         String   @id @default(cuid())
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  deviceName String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([adminId])
}

// A reseller / agency that batches filings for many client LLCs under one
// login. Created and approved by an admin (no public self-serve signup).
// Auth mirrors the customer magic-link model: the partner enters their email
// at /partner/sign-in, and if an *active* Partner row exists we email them a
// signed login link. Filings created by a partner carry `partnerId` so the
// partner dashboard can list them all, while each filing is still paid for
// individually at checkout and signed by the end client.
model Partner {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String // contact name or agency name shown in the portal
  company   String? // agency / firm name if different from `name`
  active    Boolean  @default(true) // admin can deactivate to revoke access
  createdAt DateTime @default(now())
  notes     String? // admin-only notes about this partner

  filings Filing[]
}

// One row per (user, tax year, campaign) — the unique constraint stops the
// cron from double-sending if it's re-run within a campaign window.
model ReminderSent {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The tax year being reminded about (e.g. 2026 for a January 2026 send).
  year     Int
  // Which campaign — lets us run multiple touches per year independently.
  campaign String // "january" | "march"
  sentAt   DateTime @default(now())

  @@unique([userId, year, campaign])
  @@index([year, campaign])
}

model Filing {
  id        String       @id @default(cuid())
  // userId is null while the customer is filling the wizard anonymously.
  // Set to a real User once they provide an email at the Review step.
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  // sessionId binds an anonymous filing to a browser cookie so refreshes
  // don't lose work. Cleared once the filing is linked to a user.
  sessionId String?
  // Set when a partner (reseller/agency) created this filing on behalf of a
  // client. Null for normal direct-customer filings. The end client is still
  // bound via `userId` (for signing + portal access); partnerId is an
  // additional owner used only by the partner dashboard.
  partnerId String?
  partner   Partner?     @relation(fields: [partnerId], references: [id])
  status    FilingStatus @default(DRAFT)

  // Pricing tier
  tier            String
  amountPaid      Int     @default(0)
  stripeSessionId String?
  stripePaymentId String?

  // Entity info
  llcName             String?
  llcEin              String?
  llcAddress          String?
  llcCity             String?
  llcState            String?
  llcZip              String?
  llcCountry          String    @default("USA")
  llcDateIncorporated DateTime?
  llcBusinessActivity String?
  llcBusinessCode     String?

  // Foreign owner info
  ownerName                String?
  // Concatenated address (street, city, state, postal, country) used by the
  // PDF generator. Backed by the structured parts below — saved on every
  // wizard submit so existing PDF generation keeps working unchanged.
  ownerAddress             String?
  ownerAddressStreet       String?
  ownerAddressCity         String?
  ownerAddressState        String?
  ownerAddressPostal       String?
  ownerAddressCountry      String?
  ownerCountryCitizenship  String?
  ownerCountryTaxResidence String?
  ownerCountryBusiness     String?
  ownerFtin                String?
  ownerItin                String?
  ownerReferenceId         String?

  // Filing scope
  taxYears                 Int[]
  isDiirsp                 Boolean @default(false)
  reasonableCauseNarrative String?

  // True = we fax the signed package to the IRS for the customer (+ fax fee).
  // False = customer faxes it themselves after downloading the signed PDF.
  faxService Boolean @default(true)

  // Generated PDFs (R2 keys)
  generatedPdfKey    String?
  signedPdfKey       String?
  // Snapshot of signedPdfKey taken at the moment retryFax fired. Lets the
  // admin verify exactly what was sent to the IRS even if signedPdfKey is
  // later cleared (e.g. after Regenerate PDF). Populated by the retryFax
  // action — null on legacy faxes that pre-date this field.
  faxedPdfKey        String?
  faxedAt            DateTime?
  faxJobId           String?
  faxStatus          String?
  faxConfirmationKey String?

  // In-portal signing artifact. R2 key for the customer's saved signature
  // image (PNG). Stored once per User (denormalised onto Filing so anonymous
  // sessions also work). When the customer files again later, we pre-populate
  // the SignaturePad with this image so they don't have to re-draw.
  signaturePngKey String?
  signedAt        DateTime?

  // Tracks the one-time "you didn't finish your filing" nudge so we don't
  // re-send. Null = not sent. Set timestamp on send.
  abandonedReminderSentAt DateTime?

  // Which landing-page funnel created this filing. Null = standard /start flow.
  // "file_funnel" = the /file qualifying funnel.
  funnelSource String?

  // Visitor explicitly allowed marketing measurement before this draft was
  // created. Gates Meta Conversions API events; tax and bank data are never
  // included in those events.
  marketingConsent Boolean @default(false)

  // AI compliance-check state for the generated PDF. Set by the post-payment
  // validation pipeline. Null = no validation has run yet.
  //   pending      = generated, waiting for AI check to run
  //   passed       = AI check found no issues
  //   fixed        = AI flagged an issue, regenerator auto-corrected, re-check passed
  //   needs_input  = AI flagged an issue requiring customer clarification (system message posted)
  //   error        = AI infra failed (timeout/5xx); fell open and sent PDF email anyway
  validationStatus     String?
  validationIssuesJson Json?
  validationCheckedAt  DateTime?

  // Who currently "owns" the customer support thread for the AI conversation loop.
  //   null   = no AI conversation in flight (validation hasn't flagged yet, or status is passed/error)
  //   agent  = AI is responsible for replying to the next customer message
  //   admin  = a human admin posted in the thread; AI defers indefinitely until admin re-engages
  aiHandoff   String?
  // Number of customer reply cycles the AI has handled in this session. Cap = 2
  // before forced escalation. Reset to 0 when admin re-engages or filing re-validates fresh.
  aiTurnsUsed Int     @default(0)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  yearData         FilingYearData[]
  plaidConnections PlaidConnection[]
  messages         Message[]
  changeLog        FilingChangeLog[]

  @@index([partnerId])
  // fax-status-poll (where status=FAXED order by updatedAt) + abandoned-draft
  // cron (where status=DRAFT and updatedAt in window) + reminder audience
  // selection all filter on status, often with updatedAt.
  @@index([status, updatedAt])
  // telnyx-webhook + fax-status-poll look up the filing by its Telnyx job id
  // on every inbound event.
  @@index([faxJobId])
}

// Append-only audit log for changes the AI agent (and admin) make to a
// filing's data. Visible in the admin UI as a timeline. Never deleted.
model FilingChangeLog {
  id         String   @id @default(cuid())
  filingId   String
  filing     Filing   @relation(fields: [filingId], references: [id], onDelete: Cascade)
  adminId    String?
  admin      Admin?   @relation(fields: [adminId], references: [id])
  // Who/what initiated the change. "ai" = the conversation agent, "admin" =
  // human via /admin, "customer" = self-service edit, "system" = automated
  // (cron, webhook, etc.).
  source     String
  // Dotted path or simple field name, e.g. "llcName" or "yearData[2024].contributions".
  field      String
  beforeJson Json?
  afterJson  Json?
  // Free-text reason. For AI changes, this is what the customer told us.
  reason     String?
  changedAt  DateTime @default(now())

  @@index([filingId, changedAt])
  @@index([adminId])
}

// In-portal communication between admin and customer about a specific filing.
// fromAdmin distinguishes direction. readAt is set when the OTHER party views
// (e.g. customer GET marks fromAdmin=true rows as read, and vice versa). The
// "first unread" email rule uses unread counts to debounce notifications.
model Message {
  id        String    @id @default(cuid())
  filingId  String
  filing    Filing    @relation(fields: [filingId], references: [id], onDelete: Cascade)
  fromAdmin Boolean
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([filingId, createdAt])
}

model FilingYearData {
  id                     String  @id @default(cuid())
  filingId               String
  filing                 Filing  @relation(fields: [filingId], references: [id], onDelete: Cascade)
  taxYear                Int
  totalAssetsYearEnd     Decimal @default(0) @db.Decimal(15, 2)
  contributions          Decimal @default(0) @db.Decimal(15, 2)
  distributions          Decimal @default(0) @db.Decimal(15, 2)
  reportableTransactions Json    @default("[]")
  // Free-text disclosure of any other related-party transactions during this
  // tax year (loans, sales, services, rent, etc.) — flows into the Part V
  // supporting statement. Null = user hasn't answered; empty string = explicitly
  // confirmed no other transactions.
  otherTransactionsNote  String?

  bankStatements BankStatement[]

  @@unique([filingId, taxYear])
}

model PlaidConnection {
  id              String   @id @default(cuid())
  filingId        String
  filing          Filing   @relation(fields: [filingId], references: [id], onDelete: Cascade)
  // Plaid access token — kept in the DB for simplicity. In production this
  // should be encrypted at rest with a KMS key; for now we rely on Neon's
  // at-rest encryption and the row-level filing ownership check.
  accessToken     String
  itemId          String
  institutionName String?
  createdAt       DateTime @default(now())
}

model BankStatement {
  id               String         @id @default(cuid())
  filingYearDataId String
  filingYearData   FilingYearData @relation(fields: [filingYearDataId], references: [id], onDelete: Cascade)
  fileKey          String
  fileName         String
  bankProvider     String?
  parseResult      Json?
  uploadedAt       DateTime       @default(now())
}

enum FilingStatus {
  DRAFT
  PAID
  PDF_GENERATED
  SIGNATURE_PENDING
  SIGNED_UPLOADED
  FAXED
  CONFIRMED
  FAILED
}

model EinApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName         String
  email            String
  phone            String?
  llcName          String
  llcState         String?
  llcFormedDate    String?
  businessPurpose  String?
  ownerName        String?
  ownerCitizenship String?
  ownerResidence   String?
  passportNumber   String?
  notes            String?

  status     EinStatus @default(RECEIVED)
  adminNotes String?
  ein        String? // filled when EIN is obtained

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

enum EinStatus {
  RECEIVED
  IN_REVIEW
  DOCS_REQUESTED
  PAYMENT_PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

model ItinApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName           String
  email              String
  phone              String?
  dateOfBirth        String?
  countryOfBirth     String?
  citizenship        String?
  countryOfResidence String?
  itinReason         String
  taxReturnType      String?
  usActivity         String?
  passportNumber     String?
  passportExpiry     String?
  notes              String?

  status     ItinStatus @default(RECEIVED)
  adminNotes String?
  itin       String? // filled when ITIN is issued

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

enum ItinStatus {
  RECEIVED
  IN_REVIEW
  DOCS_REQUESTED
  PAYMENT_PENDING
  CAA_SCHEDULED
  W7_SUBMITTED
  COMPLETED
  CANCELLED
}

// Fixed-window rate limiting, backed by Postgres (no external store needed).
// One row per (bucket:identifier:windowStart); count is incremented atomically.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

model IdempotencyRecord {
  id         String   @id @default(cuid())
  key        String
  scope      String
  adminId    String?
  resultJson Json?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([scope, key])
  @@index([expiresAt])
}
