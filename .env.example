# Copy to .env.local and fill in. Never commit .env.local.

# ----- Database -----
# Neon: https://console.neon.tech -> create project -> copy pooled connection string
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ----- Auth (cookie-based, no third-party) -----
# HMAC secret for the user session cookie + magic-link tokens.
# Generate with: openssl rand -hex 32
SESSION_SECRET=""
# Optional: separate secret for magic-link tokens (falls back to SESSION_SECRET).
MAGIC_LINK_SECRET=""

# ----- Google sign-in (optional) -----
# OAuth client_id from https://console.cloud.google.com → APIs & Services →
# Credentials → "Create OAuth client ID" → Web application. Add your origin
# (http://localhost:3000 + your production URL) to "Authorized JavaScript
# origins". Unset = the "Continue with Google" button shows as disabled with
# a setup hint, and the email + magic-link flow keeps working.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=""

# ----- Bank-connect (Plaid) -----
# Optional. When unset, the "Connect bank with Plaid" button returns a friendly
# error and users can still upload CSVs/PDFs. Get free Sandbox keys at
# https://dashboard.plaid.com/developers/keys.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# sandbox (fake bank data) | development (real banks, capped users) | production
PLAID_ENV="sandbox"

# ----- Email (Resend) -----
# Free tier = 3,000/mo. Sign up at https://resend.com.
# If unset, magic-link emails are logged to the server console (dev fallback).
RESEND_API_KEY=""
RESEND_FROM="Form5472 Prep <orders@form5472prep.com>"

# ----- Stripe -----
# Test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# After `stripe listen --forward-to localhost:3000/api/stripe-webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----- File storage (Cloudflare R2) -----
# R2 is S3-compatible. Create a bucket "form5472" and an R2 API token.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="form5472"
R2_PUBLIC_BASE_URL=""

# ----- Fax (Telnyx) -----
# Telnyx Programmable Fax. Sandbox until live mode is enabled.
TELNYX_API_KEY=""
TELNYX_CONNECTION_ID=""
TELNYX_FAX_NUMBER=""
# Real IRS Ogden PIN Unit destination. Override only when testing.
FAX_DESTINATION="+18558877737"

# ----- App config -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Admin (filings dashboard + blog editor at /admin) -----
# Defaults to "111111" if unset — change before going live.
ADMIN_PASSWORD="111111"
# Used to sign the admin session cookie. Generate with `openssl rand -hex 32`.
ADMIN_SESSION_SECRET=""

# ----- Cron (yearly reminder emails) -----
# Shared secret Vercel Cron sends in the Authorization header. Required in
# production; if unset, the cron routes accept any request (dev fallback).
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ----- Email reply-to (optional) -----
# Defaults to support@form5472prep.com if unset.
RESEND_REPLY_TO=""
